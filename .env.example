# LLMBase — LLM Provider Configuration
# Works with any OpenAI-compatible API: OpenAI, OpenRouter, Ollama, Together, etc.

LLMBASE_API_KEY=sk-your-api-key-here
LLMBASE_BASE_URL=https://api.openai.com/v1
LLMBASE_MODEL=gpt-4o

# ─── Examples ───────────────────────────────────────────────

# --- OpenAI ---
# LLMBASE_API_KEY=sk-...
# LLMBASE_BASE_URL=https://api.openai.com/v1
# LLMBASE_MODEL=gpt-4o

# --- OpenRouter (access 200+ models) ---
# LLMBASE_API_KEY=sk-or-...
# LLMBASE_BASE_URL=https://openrouter.ai/api/v1
# LLMBASE_MODEL=anthropic/claude-sonnet-4-6

# --- Ollama (local, free) ---
# LLMBASE_API_KEY=ollama
# LLMBASE_BASE_URL=http://localhost:11434/v1
# LLMBASE_MODEL=llama3.1

# --- Together AI ---
# LLMBASE_API_KEY=...
# LLMBASE_BASE_URL=https://api.together.xyz/v1
# LLMBASE_MODEL=meta-llama/Llama-3-70b-chat-hf

# --- Groq ---
# LLMBASE_API_KEY=gsk_...
# LLMBASE_BASE_URL=https://api.groq.com/openai/v1
# LLMBASE_MODEL=llama-3.1-70b-versatile

# You can also use the standard OpenAI env vars as fallback:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Fallback models (comma-separated, tried in order if primary fails)
# LLMBASE_FALLBACK_MODELS=deepseek-chat,gpt-4o-mini,glm-4-flash
